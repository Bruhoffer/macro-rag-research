# Database — matches docker-compose.yml
# POSTGRES_PASSWORD is picked up by docker compose for interpolation; change both together.
POSTGRES_PASSWORD=macrorag
DATABASE_URL=postgresql+asyncpg://macrorag:macrorag@localhost:5433/macrorag
DATABASE_URL_SYNC=postgresql://macrorag:macrorag@localhost:5433/macrorag

# LLM APIs
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Paths to source data (relative to backend/ directory)
RAW_DATA_DIR=../../raw-data
RAW_EMAILS_DIR=../../raw-emails

# API auth — required on all /api/* requests (Bearer token)
MACRO_RAG_API_KEY=generate_with__openssl_rand_-hex_32
ALLOWED_ORIGIN=http://localhost:8000

# Access model — defaults to the safe option. Set to "open" only for a public
# demo (browse/chat become key-free; rate limits + budget cap protect cost).
#   private = every /api/* call requires MACRO_RAG_API_KEY
#   open    = public demo
ACCESS_MODE=private
ADMIN_API_KEY=generate_with__openssl_rand_-hex_32
CHAT_DAILY_BUDGET_USD=5
